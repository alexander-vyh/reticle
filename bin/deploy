#!/usr/bin/env bash
set -euo pipefail

# Reticle Deploy Script
# Usage: bin/deploy [--skip-pull] [--skip-install]

RETICLE_HOME="$HOME/.reticle"
REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PLIST_DIR="$HOME/Library/LaunchAgents"
UID_VAL=$(id -u)

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

info()  { echo -e "${GREEN}==>${NC} $1"; }
warn()  { echo -e "${YELLOW}==>${NC} $1"; }
error() { echo -e "${RED}==>${NC} $1"; }

# Parse flags
SKIP_PULL=false
SKIP_INSTALL=false
for arg in "$@"; do
  case $arg in
    --skip-pull) SKIP_PULL=true ;;
    --skip-install) SKIP_INSTALL=true ;;
  esac
done

# --- Step 1: Create directory structure ---
info "Ensuring ~/.reticle/ directory structure..."
mkdir -p "$RETICLE_HOME"/{app,data,logs,config}

# --- Step 2: First-run migration ---
# Config: migrate from legacy paths
for legacy_dir in "$HOME/.config/claudia" "$HOME/.claudia/config"; do
  if [ -d "$legacy_dir" ] && [ ! -f "$RETICLE_HOME/config/secrets.json" ]; then
    info "Migrating config from $legacy_dir/ to ~/.reticle/config/..."
    cp -n "$legacy_dir/"* "$RETICLE_HOME/config/" 2>/dev/null || true
    warn "Old config left in place at $legacy_dir/ (remove manually when ready)"
    break
  fi
done

# Database: migrate from legacy paths
for legacy_db in "$HOME/.claudia/data/claudia.db" "$HOME/.openclaw/workspace/claudia.db"; do
  if [ -f "$legacy_db" ] && [ ! -f "$RETICLE_HOME/data/reticle.db" ]; then
    info "Migrating database from $legacy_db to ~/.reticle/data/reticle.db..."
    cp "$legacy_db" "$RETICLE_HOME/data/reticle.db"
    cp "${legacy_db}-wal" "$RETICLE_HOME/data/reticle.db-wal" 2>/dev/null || true
    cp "${legacy_db}-shm" "$RETICLE_HOME/data/reticle.db-shm" 2>/dev/null || true
    warn "Old database left in place at $legacy_db (remove manually when ready)"
    break
  fi
done

# --- Step 3: Pull latest ---
if [ "$SKIP_PULL" = false ]; then
  info "Pulling latest from main..."
  cd "$REPO_DIR"
  git pull origin main
fi

# --- Step 4: Install dependencies in repo ---
if [ "$SKIP_INSTALL" = false ]; then
  info "Installing dependencies in repo..."
  cd "$REPO_DIR"
  npm install --silent
fi

# --- Step 5: Sync code to ~/.claudia/app/ ---
info "Syncing code to ~/.reticle/app/..."
rsync -a --delete \
  --exclude='.git' \
  --exclude='node_modules' \
  --exclude='tray' \
  --exclude='docs' \
  --exclude='sounds' \
  --exclude='scripts' \
  --exclude='bin' \
  --exclude='test-*.js' \
  --exclude='*.log' \
  --exclude='*.sh' \
  --exclude='*.pid' \
  --exclude='*.db' \
  --exclude='*.db-*' \
  --exclude='.gitignore' \
  --exclude='.github' \
  --exclude='.claude' \
  --exclude='.serena' \
  --exclude='.worktrees' \
  --exclude='.gastown-ignore' \
  --exclude='CLAUDE.md' \
  --exclude='email-cache' \
  --exclude='*-state.json' \
  --exclude='*-heartbeat.json' \
  --exclude='*-batch-queue.json' \
  --exclude='*-last-check.txt' \
  "$REPO_DIR/" "$RETICLE_HOME/app/"

# --- Step 6: Install production dependencies ---
if [ "$SKIP_INSTALL" = false ]; then
  info "Installing production dependencies in ~/.reticle/app/..."
  cd "$RETICLE_HOME/app"
  npm install --omit=dev --ignore-scripts --silent
fi

# --- Build Swift targets ---
info "Building Swift targets..."
cd "$REPO_DIR/reticle"
swift build -c release 2>&1 | tail -5

# Assemble Reticle.app
RETICLE_APP="$RETICLE_HOME/Reticle.app"
info "Assembling Reticle.app..."
rm -rf "$RETICLE_APP"
mkdir -p "$RETICLE_APP/Contents/MacOS"
mkdir -p "$RETICLE_APP/Contents/Resources"
cp .build/release/Reticle "$RETICLE_APP/Contents/MacOS/"

cat > "$RETICLE_APP/Contents/Info.plist" <<'INFOPLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>ai.reticle.app</string>
  <key>CFBundleName</key>
  <string>Reticle</string>
  <key>CFBundleExecutable</key>
  <string>Reticle</string>
  <key>CFBundleVersion</key>
  <string>1.0</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0</string>
  <key>LSUIElement</key>
  <true/>
  <key>LSMinimumSystemVersion</key>
  <string>14.0</string>
</dict>
</plist>
INFOPLIST

codesign --sign "Reticle Local Dev" --force "$RETICLE_APP"

# Assemble MeetingPopup.app
POPUP_APP="$RETICLE_HOME/MeetingPopup.app"
info "Assembling MeetingPopup.app..."
rm -rf "$POPUP_APP"
mkdir -p "$POPUP_APP/Contents/MacOS"
cp .build/release/MeetingPopup "$POPUP_APP/Contents/MacOS/"

cat > "$POPUP_APP/Contents/Info.plist" <<'INFOPLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>ai.reticle.meeting-popup</string>
  <key>CFBundleName</key>
  <string>MeetingPopup</string>
  <key>CFBundleExecutable</key>
  <string>MeetingPopup</string>
  <key>CFBundleVersion</key>
  <string>1.0</string>
  <key>LSUIElement</key>
  <true/>
  <key>LSMinimumSystemVersion</key>
  <string>14.0</string>
</dict>
</plist>
INFOPLIST

codesign --sign "Reticle Local Dev" --force "$POPUP_APP"

cd "$REPO_DIR"

# --- Step 7: Generate and load launchd plists ---
info "Generating launchd plists..."

# Service definitions: label|js_file
SERVICES=(
  "gmail-monitor|gmail-monitor.js"
  "slack-events|slack-events-monitor.js"
  "meeting-alerts|meeting-alert-monitor.js"
  "followup-checker|followup-checker.js"
)

for svc in "${SERVICES[@]}"; do
  IFS='|' read -r label jsfile <<< "$svc"
  plist_label="ai.reticle.$label"
  plist_path="$PLIST_DIR/$plist_label.plist"

  cat > "$plist_path" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$plist_label</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>$RETICLE_HOME/app/$jsfile</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>NetworkState</key>
    <true/>
  </dict>
  <key>ProcessType</key>
  <string>Background</string>
  <key>ExitTimeOut</key>
  <integer>5</integer>
  <key>StandardOutPath</key>
  <string>$RETICLE_HOME/logs/$label.log</string>
  <key>StandardErrorPath</key>
  <string>$RETICLE_HOME/logs/$label-error.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>$HOME</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
  <key>ThrottleInterval</key>
  <integer>30</integer>
</dict>
</plist>
PLIST
done

# Scheduled service definitions: label|js_file
SCHEDULED_SERVICES=(
  "digest-daily|digest-daily.js"
  "digest-weekly|digest-weekly.js"
  "jira-activity-collector|jira-activity-collector.js"
  "dw-weekly-report|dw-weekly-report.js"
)

# Daily digest: weekdays at 6:00 PM
cat > "$PLIST_DIR/ai.reticle.digest-daily.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.reticle.digest-daily</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>$RETICLE_HOME/app/digest-daily.js</string>
  </array>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>18</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>KeepAlive</key>
  <false/>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>$RETICLE_HOME/logs/digest-daily.log</string>
  <key>StandardErrorPath</key>
  <string>$RETICLE_HOME/logs/digest-daily-error.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>$HOME</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
PLIST

# Weekly digest: Friday at 4:00 PM
cat > "$PLIST_DIR/ai.reticle.digest-weekly.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.reticle.digest-weekly</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>$RETICLE_HOME/app/digest-weekly.js</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>16</integer><key>Minute</key><integer>0</integer></dict>
  <key>KeepAlive</key>
  <false/>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>$RETICLE_HOME/logs/digest-weekly.log</string>
  <key>StandardErrorPath</key>
  <string>$RETICLE_HOME/logs/digest-weekly-error.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>$HOME</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
PLIST

# Jira activity collector: weekdays at 5:00 PM
cat > "$PLIST_DIR/ai.reticle.jira-activity-collector.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.reticle.jira-activity-collector</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>$RETICLE_HOME/app/jira-activity-collector.js</string>
  </array>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>KeepAlive</key>
  <false/>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>$RETICLE_HOME/logs/jira-activity-collector.log</string>
  <key>StandardErrorPath</key>
  <string>$RETICLE_HOME/logs/jira-activity-collector-error.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>$HOME</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
PLIST

# DW weekly report: Friday at 3:00 PM
cat > "$PLIST_DIR/ai.reticle.dw-weekly-report.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.reticle.dw-weekly-report</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>$RETICLE_HOME/app/dw-weekly-report.js</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>15</integer><key>Minute</key><integer>0</integer></dict>
  <key>KeepAlive</key>
  <false/>
  <key>ProcessType</key>
  <string>Background</string>
  <key>StandardOutPath</key>
  <string>$RETICLE_HOME/logs/dw-weekly-report.log</string>
  <key>StandardErrorPath</key>
  <string>$RETICLE_HOME/logs/dw-weekly-report-error.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>$HOME</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>
PLIST

# --- Step 8: Unload old openclaw plists ---
OLD_LABELS=(
  "ai.openclaw.gmail-monitor"
  "ai.openclaw.slack-monitor"
  "ai.openclaw.slack-events"
  "ai.openclaw.gateway"
  "ai.openclaw.meeting-recorder"
  "com.openclaw.meeting-alerts"
  "ai.claudia.gmail-monitor"
  "ai.claudia.slack-events"
  "ai.claudia.meeting-alerts"
  "ai.claudia.followup-checker"
  "ai.claudia.digest-daily"
  "ai.claudia.digest-weekly"
)

for old_label in "${OLD_LABELS[@]}"; do
  old_plist="$PLIST_DIR/$old_label.plist"
  if [ -f "$old_plist" ]; then
    warn "Removing old plist: $old_label"
    launchctl bootout "gui/$UID_VAL/$old_label" 2>/dev/null || true
    rm -f "$old_plist"
  fi
done

# --- Step 9: Load new plists and start services ---
info "Loading services..."
for svc in "${SERVICES[@]}"; do
  IFS='|' read -r label jsfile <<< "$svc"
  plist_label="ai.reticle.$label"
  plist_path="$PLIST_DIR/$plist_label.plist"

  # Try bootstrap first; if already loaded, kickstart to restart
  if ! launchctl bootstrap "gui/$UID_VAL" "$plist_path" 2>/dev/null; then
    launchctl kickstart -k "gui/$UID_VAL/$plist_label" 2>/dev/null || true
  fi
done

# Load scheduled services
for svc in "${SCHEDULED_SERVICES[@]}"; do
  IFS='|' read -r label jsfile <<< "$svc"
  plist_label="ai.reticle.$label"
  plist_path="$PLIST_DIR/$plist_label.plist"

  if ! launchctl bootstrap "gui/$UID_VAL" "$plist_path" 2>/dev/null; then
    launchctl kickstart -k "gui/$UID_VAL/$plist_label" 2>/dev/null || true
  fi
done

# --- Step 10: Report status ---
sleep 2
info "Service status:"
echo ""
for svc in "${SERVICES[@]}"; do
  IFS='|' read -r label jsfile <<< "$svc"
  plist_label="ai.reticle.$label"

  status_line=$(launchctl list 2>/dev/null | grep "$plist_label" || true)
  if [ -n "$status_line" ]; then
    pid_col=$(echo "$status_line" | awk '{print $1}')
    exit_col=$(echo "$status_line" | awk '{print $2}')
    if [ "$pid_col" != "-" ]; then
      echo -e "  ${GREEN}running${NC}  $label (PID $pid_col)"
    elif [ "$exit_col" = "0" ]; then
      echo -e "  ${YELLOW}stopped${NC}  $label (exit 0)"
    else
      echo -e "  ${RED}error${NC}    $label (exit $exit_col)"
    fi
  else
    echo -e "  ${RED}unloaded${NC} $label"
  fi
done

echo ""
info "Scheduled services:"
for svc in "${SCHEDULED_SERVICES[@]}"; do
  IFS='|' read -r label jsfile <<< "$svc"
  plist_label="ai.reticle.$label"

  status_line=$(launchctl list 2>/dev/null | grep "$plist_label" || true)
  if [ -n "$status_line" ]; then
    echo -e "  ${GREEN}loaded${NC}   $label (scheduled)"
  else
    echo -e "  ${RED}unloaded${NC} $label"
  fi
done

echo ""
info "Launching Reticle.app..."
open "$RETICLE_HOME/Reticle.app"

echo ""
info "Deploy complete!"

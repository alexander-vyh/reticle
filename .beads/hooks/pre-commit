#!/usr/bin/env sh
# --- BEGIN BEADS INTEGRATION v0.59.0 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  bd hooks run pre-commit "$@"
  _bd_exit=$?; if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v0.59.0 ---

# --- BEGIN GITLEAKS ---
# Prevent committing secrets (was in .git/hooks/pre-commit before beads moved hooksPath)
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner
  if [ $? -ne 0 ]; then
    echo "gitleaks: secrets detected in staged files. Commit blocked."
    exit 1
  fi
fi
# --- END GITLEAKS ---

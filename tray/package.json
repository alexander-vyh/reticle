{
  "name": "reticle-tray",
  "version": "1.0.0",
  "description": "Reticle menu bar service manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test-service-manager.js",
    "build": "rm -rf dist && electron-builder --mac --dir",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "ai.reticle.tray",
    "productName": "Reticle",
    "mac": {
      "category": "public.app-category.utilities",
      "type": "development",
      "target": "dir",
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "files": [
      "main.js",
      "service-manager.js",
      "icons.js",
      "assets/**"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
